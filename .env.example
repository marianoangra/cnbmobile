# Copie este arquivo para .env e preencha os valores reais.
# Nunca commite o .env — ele está no .gitignore.
# Para builds EAS, adicione como EAS Secret:
#   eas secret:create --scope project --name EXPO_PUBLIC_HELIUS_KEY --value SUA_KEY

EXPO_PUBLIC_HELIUS_KEY=sua-api-key-aqui

# ─── Kora paymaster (Solana) ─────────────────────────────────────────────
# O paymaster vive como Cloud Function (`assinarTxKora`). Só precisa do
# pubkey aqui — o app monta a tx com esse feePayer e a Function valida + assina.
# Sem isso, as telas Enviar CNB e Swap CNB→SOL ficam desativadas.
EXPO_PUBLIC_KORA_PUBKEY=PUBKEY_DO_PAYMASTER_EM_BASE58
